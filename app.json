{
  "expo": {
    "name": "Guru",
    "slug": "guru",
    "version": "1.0.7",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "guru",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.phantom.guruedutech",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Guru needs access to your photo library so you can choose a profile picture. For example, you can select a photo from your library to display on your account and on school leaderboards.",
        "NSPhotoLibraryAddUsageDescription": "Guru may save your updated profile photo to your photo library when you choose to keep a copy on your device.",
        "NSCameraUsageDescription": "Guru uses your camera so you can take a new profile photo to display on your account and school leaderboards."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#373737",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS"
      ],
      "googleServicesFile": "./google-services.json",
      "package": "com.phantom.guruedutech"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3603875446667492~8760578808",
          "iosAppId": "ca-app-pub-3603875446667492~5124586123",
          "delayAppMeasurementInit": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notifications.png",
          "color": "#689F38",
          "defaultChannel": "default",
          "sounds": [
            "./assets/sounds/alert_notification.wav"
          ],
          "enableBackgroundRemoteNotifications": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#373737",
          "dark": {
            "backgroundColor": "#373737"
          }
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow Guru App to access your contacts."
        }
      ],
      "expo-font",
      "@sentry/react-native",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "guru-edutech"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "22260cf2-a686-42bd-9c40-8aa6580ca694"
      },
      "router": {}
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/22260cf2-a686-42bd-9c40-8aa6580ca694"
    },
    "owner": "dhannnyphantom"
  }
}
